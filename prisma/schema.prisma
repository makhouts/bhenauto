generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Car {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  brand        String
  model        String
  year         Int
  mileage      Int
  fuel_type    String
  transmission String
  price        Float
  horsepower   Int
  color        String
  description  String
  featured     Boolean  @default(false)
  sold         Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  images       Image[]
}

model Image {
  id        String   @id @default(cuid())
  url       String
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Contact {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  message       String
  car_reference String?
  createdAt     DateTime @default(now())
}
