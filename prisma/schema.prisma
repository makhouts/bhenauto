generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Car {
  id                       String    @id @default(cuid())
  slug                     String    @unique
  title                    String
  brand                    String
  model                    String
  year                     Int
  mileage                  Int
  fuel_type                String
  transmission             String
  price                    Float
  horsepower               Int
  color                    String
  description              String
  featured                 Boolean   @default(false)
  sold                     Boolean   @default(false)
  reserved                 Boolean   @default(false)
  soldAt                   DateTime?
  carpass_url              String?
  features                 String[]  @default([])
  externalSource           String?
  externalListingId        String?
  importSource             String?
  sourceOfTruth            String    @default("website")
  autoscoutListingId       String?   @unique
  autoscoutCustomerId      String?
  autoscoutUrl             String?
  autoscoutLastPushedAt    DateTime?
  autoscoutSyncStatus      String?
  autoscoutSyncError       String?
  autoscoutTestMode        Boolean   @default(false)
  lastAutoscoutPayload     Json?
  lastAutoscoutPayloadHash String?
  lastSyncedAt             DateTime?
  sourcePayload            Json?
  sourcePayloadUpdatedAt   DateTime?
  vin                      String?
  referenceNumber          String?
  crossReferenceId         String?
  licencePlate             String?
  version                  String?
  makeCode                 String?
  modelCode                String?
  bodyType                 String?
  bodyTypeCode             String?
  vehicleType              String?
  vehicleTypeCode          String?
  offerTypeCode            String?
  availabilityTypeCode     String?
  fuelTypeCode             String?
  fuelCategory             String?
  additionalFuelTypeCodes  String[]  @default([])
  isPluginHybrid           Boolean?
  transmissionCode         String?
  drivetrain               String?
  drivetrainCode           String?
  powerKw                  Int?
  engineSize               Int?
  cylinderCount            Int?
  firstRegistrationDate    DateTime?
  firstRegistrationRaw     String?
  constructionYear         Int?
  doors                    Int?
  seats                    Int?
  exteriorColor            String?
  exteriorColorCode        String?
  manufacturerColorName    String?
  interiorColor            String?
  interiorColorCode        String?
  upholstery               String?
  upholsteryCode           String?
  emissionClass            String?
  emissionClassCode        String?
  co2Emissions             Int?
  consumptionCombined      Float?
  consumption              Json?
  wltp                     Json?
  priceCurrency            String    @default("EUR")
  netPrice                 Int?
  vatRate                  Float?
  vatDeductible            Boolean?
  priceNegotiable          Boolean?
  warrantyMonths           Int?
  warrantyText             String?
  hasWarranty              Boolean?
  availabilityStatus       String?
  publicationStatus        String?
  equipmentCodes           String[]  @default([])
  equipment                Json?
  technicalData            Json?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  images                   Image[]

  @@unique([externalSource, externalListingId])
  @@index([brand])
  @@index([sold, reserved])
  @@index([soldAt])
  @@index([createdAt])
  @@index([externalSource])
  @@index([lastSyncedAt])
  @@index([autoscoutSyncStatus])
  @@index([lastAutoscoutPayloadHash])
  @@index([sourceOfTruth])
  @@index([publicationStatus])
}

model Image {
  id               String   @id @default(cuid())
  url              String
  sortOrder        Int      @default(0)
  sourceUrl        String?
  autoscoutImageId String?
  sourceMd5        String?
  carId            String
  car              Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@index([carId])
  @@index([carId, sortOrder])
  @@index([autoscoutImageId])
}

model AutoScoutReference {
  id            String   @id @default(cuid())
  referenceType String
  referenceId   String
  nameNl        String?
  nameFr        String?
  nameEn        String?
  vehicleTypes  String[] @default([])
  countries     String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([referenceType, referenceId])
  @@index([referenceType])
}

model AutoScoutMakeCache {
  makeId       String   @id
  name         String
  models       Json
  vehicleTypes String[] @default([])
  refreshedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([refreshedAt])
}

model AutoScoutSyncJob {
  id                String    @id @default(cuid())
  carId             String?
  action            String
  publicationStatus String?
  status            String    @default("pending")
  priority          Int       @default(0)
  attempts          Int       @default(0)
  maxAttempts       Int       @default(5)
  nextRunAt         DateTime  @default(now())
  lockedAt          DateTime?
  lockedUntil       DateTime?
  finishedAt        DateTime?
  dedupeKey         String?   @unique
  customerId        String?
  listingId         String?
  crossReferenceId  String?
  payloadHash       String?
  lastError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, nextRunAt])
  @@index([carId])
  @@index([action])
  @@index([listingId])
  @@index([createdAt])
  @@index([finishedAt])
}

model AutoScoutSyncLog {
  id              String   @id @default(cuid())
  jobId           String?
  carId           String?
  action          String
  status          String
  attempt         Int?
  message         String?
  payloadHash     String?
  customerId      String?
  listingId       String?
  requestPayload  Json?
  responsePayload Json?
  errorPayload    Json?
  createdAt       DateTime @default(now())

  @@index([jobId])
  @@index([carId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model AutoScoutImportState {
  id              String   @id
  ownerId         String?
  status          String   @default("idle")
  startedAt       DateTime?
  heartbeatAt     DateTime?
  lockedUntil     DateTime?
  lastCompletedAt DateTime?
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, lockedUntil])
}

model Contact {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  message       String
  car_reference String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
}

model Appointment {
  id            String            @id @default(cuid())
  date          DateTime // UTC midnight of the chosen day
  timeSlot      String // e.g. "09:00"
  name          String
  email         String
  phone         String
  service       String
  notes         String?
  locale        String            @default("fr") // nl | fr | en — language for email notifications
  status        AppointmentStatus @default(pending)
  durationHours Int               @default(1) // how many hours this appointment occupies
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([date, status])
  @@index([date, timeSlot, status])
  @@index([email, createdAt])
  @@index([status])
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime // UTC midnight of the blocked day
  timeSlot  String? // null = entire day blocked, "HH:MM" = specific slot only
  reason    String?
  createdAt DateTime @default(now())

  // Partial unique indexes for full-day and slot blocks are managed in SQL migrations.
}
