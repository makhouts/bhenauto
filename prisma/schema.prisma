generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Car {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  brand        String
  model        String
  year         Int
  mileage      Int
  fuel_type    String
  transmission String
  price        Float
  horsepower   Int
  color        String
  description  String
  featured     Boolean  @default(false)
  sold         Boolean  @default(false)
  reserved     Boolean  @default(false)
  carpass_url  String?
  features     String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  images       Image[]

  @@index([brand])
  @@index([sold, reserved])
  @@index([createdAt])
}

model Image {
  id        String   @id @default(cuid())
  url       String
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Contact {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  message       String
  car_reference String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
}

model Appointment {
  id            String            @id @default(cuid())
  date          DateTime          // UTC midnight of the chosen day
  timeSlot      String            // e.g. "09:00"
  name          String
  email         String
  phone         String
  service       String
  notes         String?
  status        AppointmentStatus @default(pending)
  durationHours Int               @default(1) // how many hours this appointment occupies
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([date, status])
  @@index([status])
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime             // UTC midnight of the blocked day
  timeSlot  String?              // null = entire day blocked, "HH:MM" = specific slot only
  reason    String?
  createdAt DateTime @default(now())

  @@unique([date, timeSlot]) // prevent duplicates (null treated as one unique value per date)
}
